{
  "name": "zotkit-zotero-plugin",
  "version": "0.2.3",
  "private": true,
  "description": "A real Codex or Claude Code terminal with bounded, read-only PDF context inside Zotero Reader.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run check && npm test && npm run build",
    "native:test": "make -C native test",
    "native:universal": "make -C native universal"
  },
  "devDependencies": {
    "@types/node": "24.1.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "esbuild": "0.28.1",
    "happy-dom": "20.11.0",
    "katex": "0.18.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
