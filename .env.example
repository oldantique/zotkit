# zotkit credentials — copy to one of:
#   ./.env  (project dir)   |   ~/.config/zotkit/env   |   any path in $ZOTKIT_ENV
# Do NOT commit the real file.

# --- Zotero Web API ---
# Create a key at https://www.zotero.org/settings/keys (allow library write access).
# Your numeric userID is shown on that same page.
ZOTERO_LIBRARY_ID=1234567
# "user" for a personal library, "group" for a group library
ZOTERO_LIBRARY_TYPE=user
ZOTERO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- WebDAV file syncing (only needed for attach/fetch) ---
# Copy the exact values from the Zotero DESKTOP app on any of your machines:
#   Settings/Preferences -> Sync -> File Syncing  (the "WebDAV" section)
# IMPORTANT: Zotero appends "/zotero/" to the URL shown in that dialog —
# include it here. E.g. desktop shows https://dav.example.com  ->  use:
WEBDAV_URL=https://dav.example.com/zotero/
WEBDAV_USER=you@example.com
WEBDAV_PASS=secret
